// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
  
  arrayUserId String?
  arrayApiKey String?
  
  creditReports CreditReport[]
  disputeRounds DisputeRound[]
}

model CreditReport {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  
  filename   String
  mimeType   String
  fileSize   Int
  uploadedAt DateTime @default(now())
  
  rawText    String?  @db.Text
  rawBytes   Bytes?
  sha256     String?  @unique
  storageProvider String @default("db")
  s3Bucket   String?
  s3ObjectKey String?
  
  sourceType  String
  bureauType  String?
  parsedData  Json
  reportFingerprint String?
  
  firstName   String?
  lastName    String?
  ssnLast4    String?
  dateOfBirth DateTime?
  accountNumber String?
  accountType   String?
  accountStatus String?
  balance       Decimal?
  openedDate    DateTime?
  closedDate    DateTime?
  
  disputeRounds DisputeRound[]
  
  @@index([userId, reportFingerprint])
  @@index([userId, uploadedAt])
}

model DisputeRound {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  creditReportId  String
  creditReport    CreditReport @relation(fields: [creditReportId], references: [id], onDelete: Cascade)
  
  roundNumber     Int
  status          String
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  completedAt     DateTime?
  sentAt          DateTime?
  
  selectedItemIds Json
  disputeReasons  Json
  letterGenerated Boolean  @default(false)
  letterContent   String?  @db.Text
  
  bureausTargeted Json
  itemCount       Int      @default(0)
  
  @@unique([creditReportId, roundNumber])
  @@index([userId, creditReportId])
  @@index([userId, status])
}
